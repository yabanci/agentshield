{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "state-timeline",
      "name": "State timeline",
      "version": ""
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "AgentShield resilience metrics: request flow, semantic quality, latency, and defensive systems",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Request Flow",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "primary"},
            "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "fallback"},
            "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "denied"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "cache"},
            "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (tier) (rate(agentshield_requests_total[1m]))",
          "legendFormat": "{{tier}}"
        }
      ],
      "title": "Requests/sec by tier",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 30}
            ]
          },
          "unit": "percent",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(increase(agentshield_requests_total{tier=\"fallback\"}[5m])) / clamp_min(sum(increase(agentshield_requests_total[5m])), 1)",
          "legendFormat": "Fallback rate"
        }
      ],
      "title": "Fallback rate % (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "percent",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(increase(agentshield_requests_total{tier=\"denied\"}[5m])) / clamp_min(sum(increase(agentshield_requests_total[5m])), 1)",
          "legendFormat": "Denial rate"
        }
      ],
      "title": "Graceful denial rate % (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 5},
      "id": 5,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(agentshield_cache_hits_total[5m]))",
          "legendFormat": "Cache hits"
        }
      ],
      "title": "Cache hits (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 5},
      "id": 6,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "agentshield_cache_size",
          "legendFormat": "Cache entries"
        }
      ],
      "title": "Cache size",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 10,
      "title": "Quality — the killer feature",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.8}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 11,
      "options": {
        "legend": {"calcs": ["mean", "min", "last"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "agentshield_quality_score",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "Quality score per model",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"lineWidth": 0, "fillOpacity": 70},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          },
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "Healthy"}}, "type": "value"},
            {"options": {"1": {"color": "yellow", "index": 1, "text": "Degraded"}}, "type": "value"},
            {"options": {"2": {"color": "red", "index": 2, "text": "Failing"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 10},
      "id": 12,
      "options": {
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "alignValue": "center",
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "agentshield_semantic_cb_state",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "Semantic CB state (0=Healthy 1=Degraded 2=Failing)",
      "type": "state-timeline"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"lineWidth": 0, "fillOpacity": 70},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          },
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "Closed"}}, "type": "value"},
            {"options": {"1": {"color": "yellow", "index": 1, "text": "HalfOpen"}}, "type": "value"},
            {"options": {"2": {"color": "red", "index": 2, "text": "Open"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 14},
      "id": 13,
      "options": {
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "alignValue": "center",
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "agentshield_cb_state",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "Transport CB state (0=Closed 1=HalfOpen 2=Open)",
      "type": "state-timeline"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 20,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 21,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(agentshield_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tier}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum by (le, tier) (rate(agentshield_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tier}}"
        }
      ],
      "title": "Request latency p50/p95 by tier",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "scheme", "scheme": "Spectral"},
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 22,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"mode": "single", "yHistogram": false},
        "yAxis": {"axisPlacement": "left", "decimals": 1, "reverse": false, "unit": "s"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (le) (rate(agentshield_request_duration_seconds_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "title": "Request duration heatmap (all tiers)",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 30,
      "title": "Defenses",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"lineWidth": 2, "fillOpacity": 20},
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 28},
      "id": 31,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(agentshield_loadshed_total[1m])",
          "legendFormat": "load-shed/s"
        }
      ],
      "title": "Load-shed events/sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 7, "w": 7, "x": 6, "y": 28},
      "id": 32,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (type) (rate(agentshield_bulkhead_full_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "title": "Bulkhead-full events/sec by type",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 7, "w": 5, "x": 13, "y": 28},
      "id": 33,
      "options": {
        "reduceOptions": {"calcs": ["sum"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(agentshield_webhook_dropped_total[5m])",
          "legendFormat": "Webhook drops"
        }
      ],
      "title": "Webhook drops (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1}
            ]
          }
        }
      },
      "gridPos": {"h": 7, "w": 6, "x": 18, "y": 28},
      "id": 34,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(agentshield_hedge_fires_total[1m])",
          "legendFormat": "hedge fires/s"
        }
      ],
      "title": "Hedge fires/sec",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["agentshield", "llm", "resilience"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
